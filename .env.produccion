# Configuracion de PDFexport en PRODUCCION
# Copiar este archivo a .env y ajustar los valores

# Configuracion del servidor Publica
HOST=0.0.0.0 # siempre para flask en docker
PORT=
DEBUG=true

# Config Local Docker
NETWORK_IP=172.20.0.3
NETWORK=front-net

# Configuracion Archivos
FILE_RETENTION_HOURS=24
MAX_FILE_SIZE=2147483648
NLM_INGESTOR_URL=172.20.0.4:5001
TIKA_URL=http://tika:9998

# Configuracion del frontend
TIMEOUT=10000
RETRY_ATTEMPTS=3